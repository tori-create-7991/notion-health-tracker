<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- "development" works with a free Apple ID personal-team cert.
         The app expires every 7 days and can only be installed on
         devices you have registered in Xcode. -->
    <key>method</key>
    <string>development</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>compileBitcode</key>
    <false/>
    <key>stripSwiftSymbols</key>
    <true/>
    <!-- <none> = universal (no app thinning), so the .ipa works on any device -->
    <key>thinning</key>
    <string>&lt;none&gt;</string>
</dict>
</plist>
